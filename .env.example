# SMTP Configuration for Email Verification & Password Reset
# Copy this file to '.env' and fill in your details

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com

# For Gmail: Use a 16-character App Password (not your regular account password).
# Guide to generate App Password:
# 1. Go to your Google Account Settings -> Security
# 2. Turn on "2-Step Verification" (if not already enabled)
# 3. Search for "App Passwords" or go to Google Account app password generation
# 4. Generate a new App Password for "Mail" / "Other (Custom Name)"
# 5. Copy the 16-character code and paste it below (without spaces)
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Primary Admin Configuration
ADMIN_EMAIL=admin@example.com

# Resend API Configuration (alternative to SMTP)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=onboarding@resend.dev

# Cloudinary Configuration for Image Cloud Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

